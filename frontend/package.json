    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "jsdom": "^26.0.0",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0",
