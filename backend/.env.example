APP_NAME="Anil ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=fa
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fa_IR
APP_TIMEZONE=UTC
LOG_CHANNEL=stderr
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=anil_erp
DB_USERNAME=anil
DB_PASSWORD=change-me
DB_SSLMODE=prefer

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_ENCRYPT=true
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

# Required by `php artisan db:seed` in local/development only.
# Leave both unset in production to avoid creating an administrator.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
