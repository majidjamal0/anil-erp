{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "anil-erp/backend", "type": "project",
  "require": {"php": "^8.4", "laravel/framework": "^12.0", "laravel/sanctum": "^4.0", "spatie/laravel-permission": "^6.0"},
  "require-dev": {"laravel/pint": "^1.0", "pestphp/pest": "^3.0", "pestphp/pest-plugin-laravel": "^3.0"},
  "autoload": {"psr-4": {"App\\": "app/", "Database\\Factories\\": "database/factories/", "Database\\Seeders\\": "database/seeders/"}},
  "autoload-dev": {"psr-4": {"Tests\\": "tests/"}},
  "scripts": {"test": "pest", "lint": "pint --test", "post-autoload-dump": ["Illuminate\\Foundation\\ComposerScripts::postAutoloadDump", "@php artisan package:discover --ansi"]},
  "config": {"optimize-autoloader": true, "preferred-install": "dist", "sort-packages": true}, "minimum-stability": "stable", "prefer-stable": true
}
